# ── Local Development ─────────────────────────────────────────────────────────
# Copy this file to .env.local and fill in your local backend URLs

# Backend API URL (HTTP)
NEXT_PUBLIC_API_URL=http://localhost:8000

# WebSocket URL (for real-time features)
NEXT_PUBLIC_WS_URL=ws://localhost:8000

# ── Production (Railway) ───────────────────────────────────────────────────────
# For Railway deployment:
# 1. Go to Railway dashboard → your-frontend-service → Variables
# 2. Add these environment variables:
#    - NEXT_PUBLIC_API_URL: https://your-backend-service.up.railway.app
#    - NEXT_PUBLIC_WS_URL: wss://your-backend-service.up.railway.app
# 
# Replace "your-backend-service" with your actual backend service name from Railway
